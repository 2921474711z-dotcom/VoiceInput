POSTGRES_DB=voiceinput_pro
POSTGRES_USER=voiceinput
POSTGRES_PASSWORD=voiceinput123
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=voiceinput-pro
SPRING_SERVER_PORT=8080
VITE_PORT=5173
APP_BASE_URL=http://localhost
FRONTEND_URL=http://localhost:5173

# Xiaomi MiMo Token Plan 一体方案
# 注意：项目代码会自行补 /v1/...，这里不要重复写尾部 /v1
# ASR 使用 MiMo 音频理解：chat/completions + input_audio(base64)
ASR_PROVIDER=xiaomi-mimo
ASR_BASE_URL=https://token-plan-cn.xiaomimimo.com
ASR_API_KEY=
ASR_MODEL=mimo-v2.5

LLM_PROVIDER=xiaomi-mimo
LLM_BASE_URL=https://token-plan-cn.xiaomimimo.com
LLM_API_KEY=
LLM_MODEL=mimo-v2.5-pro

MODEL_TIMEOUT_SECONDS=120
MODEL_MAX_RETRIES=2
ASR_PRICE_PER_MINUTE=0.006
LLM_INPUT_PRICE_PER_1K=0.0008
LLM_OUTPUT_PRICE_PER_1K=0.0032

SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/voiceinput_pro
SPRING_DATASOURCE_USERNAME=voiceinput
SPRING_DATASOURCE_PASSWORD=voiceinput123
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379
MINIO_ENDPOINT=http://minio:9000
QUEUE_NAME=voiceinput:tasks
